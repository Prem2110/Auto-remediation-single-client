# CPI Knowledge Base — HANA Vector Store
# These variables are shared with the main HANA connection.
# Add / update them in your .env file.

HANA_ADDRESS=<your-guid>.hna0.prod-us10.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=<HDI_RT_user>
HANA_PASSWORD=<password>
HANA_SCHEMA=AI_USE_CASES_HDI_DB_1
HANA_TABLE_VECTOR=CPI_KNOWLEDGE_BASE

# ── Actual table schema (CPI_KNOWLEDGE_BASE) ──────────────────────────────────
# Column       Type             Description
# VEC_TEXT     NCLOB            Full knowledge base text (searched by CONTAINS/LIKE)
# VEC_META     NCLOB            JSON metadata — expected keys:
#                                 id / note_id       — unique identifier
#                                 title / note_title — short description
#                                 error_category     — e.g. MAPPING_ERROR, AUTH_ERROR
#                                 solution_steps     — step-by-step fix guidance
#                                 source / url       — reference link (optional)
# VEC_VECTOR   REAL_VECTOR(0)   Pre-computed embedding (used for cosine similarity
#                                when an embedding model deployment is available)
